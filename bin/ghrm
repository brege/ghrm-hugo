#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
THEME_DIR="$SCRIPT_DIR/../theme/gh-readme"

if ! command -v hugo &>/dev/null; then
  echo "error: hugo not found in PATH" >&2
  exit 1
fi

if [[ $# -lt 1 ]]; then
  echo "usage: ghrm <file.md>" >&2
  exit 1
fi

target="$(realpath "$1")"
target_dir="$(dirname "$target")"
target_name="$(basename "$target")"

if [[ ! -f "$target" ]]; then
  echo "error: $target not found" >&2
  exit 1
fi

if [[ "$target" != *.md ]]; then
  echo "error: $target is not a markdown file" >&2
  exit 1
fi

"$SCRIPT_DIR/assets.js"

tmpdir=$(mktemp -d /tmp/ghrm-XXXXXX)
hugo_pid=""
watch_pid=""

cleanup() {
  if [[ -n "$watch_pid" ]]; then
    kill "$watch_pid" 2>/dev/null || true
  fi
  if [[ -n "$hugo_pid" ]]; then
    kill "$hugo_pid" 2>/dev/null || true
  fi
  rm -rf "$tmpdir"
}
trap cleanup EXIT INT TERM

mkdir -p "$tmpdir/content" "$tmpdir/themes"
ln -s "$THEME_DIR" "$tmpdir/themes/gh-readme"

port="${GHRM_PORT:-1313}"
while ss -tln "sport = :$port" 2>/dev/null | grep -q "$port"; do
  port=$((port + 1))
done

sync_target() {
  cp "$target" "$tmpdir/content/_index.md"
}

sync_target

printf 'baseURL = "http://localhost:%d/"\ntitle = "README Preview"\ntheme = "gh-readme"\ndisableKinds = ["taxonomy", "term", "RSS", "sitemap", "robotsTXT", "404"]\nenableEmoji = true\n\n[markup.goldmark.renderer]\n  unsafe = true\n\n[markup.goldmark.extensions]\n  strikethrough = true\n  linkify = true\n  taskList = true\n  footnote = true\n  typographer = true\n\n[markup.highlight]\n  noClasses = false\n\n[[module.mounts]]\n  source = "themes/gh-readme/assets"\n  target = "assets"\n\n[[module.mounts]]\n  source = "%s"\n  target = "static"\n' "$port" "$target_dir" > "$tmpdir/hugo.toml"

if command -v inotifywait &>/dev/null; then
  (
    while read -r changed; do
      if [[ "$changed" == "$target_name" ]] && [[ -f "$target" ]]; then
        sync_target
      fi
    done < <(
      inotifywait \
        --monitor \
        --quiet \
        --event close_write,moved_to,create \
        --format '%f' \
        "$target_dir"
    )
  ) &
  watch_pid=$!
else
  (
    last_mtime="$(stat --format '%Y' "$target")"
    while true; do
      sleep 1
      if [[ ! -f "$target" ]]; then
        continue
      fi
      current_mtime="$(stat --format '%Y' "$target")"
      if [[ "$current_mtime" != "$last_mtime" ]]; then
        sync_target
        last_mtime="$current_mtime"
      fi
    done
  ) &
  watch_pid=$!
fi

hugo server --source "$tmpdir" --port "$port" --bind 127.0.0.1 --disableFastRender &
hugo_pid=$!

sleep 1
xdg-open "http://localhost:$port/" &>/dev/null &

wait "$hugo_pid"
