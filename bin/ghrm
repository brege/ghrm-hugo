#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
THEME_DIR="$SCRIPT_DIR/../theme/gh-readme"
VENDOR_DIR="$THEME_DIR/static/vendor"

if ! command -v hugo &>/dev/null; then
  echo "error: hugo not found in PATH" >&2
  exit 1
fi

if [[ $# -lt 1 ]]; then
  echo "usage: ghrm <file.md | directory>" >&2
  exit 1
fi

target="$(realpath "$1")"

if [[ -d "$target" ]]; then
  mode="dir"
elif [[ -f "$target" ]]; then
  if [[ "$target" != *.md ]]; then
    echo "error: $target is not a markdown file" >&2
    exit 1
  fi
  mode="file"
else
  echo "error: $target not found" >&2
  exit 1
fi

CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
CACHE_DIR="$CACHE_HOME/ghrm"
HUGO_CACHE_DIR="$CACHE_DIR/hugo"
target_key="$(
  printf '%s' "$mode:$target" | sha256sum | cut --delimiter=' ' --fields=1
)"
SITE_DIR="$CACHE_DIR/sites/$target_key"
CONTENT_DIR="$SITE_DIR/content"
STATIC_DIR="$SITE_DIR/static"

required_assets=(
  "$VENDOR_DIR/mermaid.js"
  "$VENDOR_DIR/mermaid-version.txt"
  "$VENDOR_DIR/svg-pan-zoom.min.js"
  "$VENDOR_DIR/katex/katex.min.css"
  "$VENDOR_DIR/katex/katex.min.js"
  "$VENDOR_DIR/katex/auto-render.min.js"
  "$VENDOR_DIR/leaflet/leaflet.css"
  "$VENDOR_DIR/leaflet/leaflet.js"
  "$VENDOR_DIR/topojson-client.min.js"
)

for asset in "${required_assets[@]}"; do
  if [[ ! -f "$asset" ]]; then
    echo "error: missing vendor asset: $asset" >&2
    echo "run 'make assets' while online to refresh bundled dependencies" >&2
    exit 1
  fi
done

hugo_pid=""
watch_pid=""

cleanup() {
  if [[ -n "$watch_pid" ]]; then
    kill "$watch_pid" 2>/dev/null || true
  fi
  if [[ -n "$hugo_pid" ]]; then
    kill "$hugo_pid" 2>/dev/null || true
  fi
}
trap cleanup EXIT INT TERM

mkdir --parents "$CONTENT_DIR" "$STATIC_DIR" "$SITE_DIR/themes" "$HUGO_CACHE_DIR"
ln --symbolic --force --no-target-directory \
  "$THEME_DIR" \
  "$SITE_DIR/themes/gh-readme"

port="${GHRM_PORT:-1313}"
while ss -tln "sport = :$port" 2>/dev/null | grep -q "$port"; do
  port=$((port + 1))
done

list_markdown_files() {
  if command -v fd &>/dev/null; then
    (
      cd "$target"
      fd \
        --type file \
        --extension md \
        --extension MD \
        --hidden \
        --no-ignore \
        --exclude .git \
        --exclude .claude \
        --exclude .venv \
        --exclude node_modules \
        --print0 \
        .
    )
    return
  fi

  (
    cd "$target"
    find \
      . \
      -type f \
      \( -name '*.md' -o -name '*.MD' \) \
      ! -path './.git/*' \
      ! -path './.claude/*' \
      ! -path './.venv/*' \
      ! -path './node_modules/*' \
      -print0
  )
}

strip_front_matter() {
  local src="$1"
  local dst="$2"
  local first_line=""

  if ! IFS= read -r first_line < "$src"; then
    : > "$dst"
    return
  fi

  case "$first_line" in
    "---")
      if tail --lines=+2 "$src" \
        | grep --quiet --extended-regexp '^(---|\.\.\.)$'; then
        sed '1,/^\(---\|\.\.\.\)$/d' "$src" > "$dst"
        return
      fi
      ;;
    "+++")
      if tail --lines=+2 "$src" \
        | grep --quiet --extended-regexp '^\+\+\+$'; then
        sed '1,/^\+\+\+$/d' "$src" > "$dst"
        return
      fi
      ;;
  esac

  cp --force "$src" "$dst"
}

if [[ "$mode" == "file" ]]; then
  target_dir="$(dirname "$target")"
  target_name="$(basename "$target")"

  sync_target() {
    cp --force "$target" "$CONTENT_DIR/_index.md"
  }

  sync_target

  printf 'baseURL = "http://localhost:%d/"\ntitle = "README Preview"\ntheme = "gh-readme"\ndisableKinds = ["section", "taxonomy", "term", "RSS", "sitemap", "robotsTXT", "404"]\nenableEmoji = true\n\n[markup.goldmark.renderer]\n  unsafe = true\n\n[markup.goldmark.extensions]\n  strikethrough = true\n  linkify = true\n  taskList = true\n  footnote = true\n  typographer = true\n\n[markup.highlight]\n  noClasses = false\n\n[[module.mounts]]\n  source = "themes/gh-readme/assets"\n  target = "assets"\n\n[[module.mounts]]\n  source = "%s"\n  target = "static"\n' "$port" "$target_dir" > "$SITE_DIR/hugo.toml"

  if command -v inotifywait &>/dev/null; then
    (
      while read -r changed; do
        if [[ "$changed" == "$target_name" ]] && [[ -f "$target" ]]; then
          sync_target
        fi
      done < <(
        inotifywait \
          --monitor \
          --quiet \
          --event close_write,moved_to,create \
          --format '%f' \
          "$target_dir"
      )
    ) &
    watch_pid=$!
  else
    (
      last_mtime="$(stat --format '%Y' "$target")"
      while true; do
        sleep 1
        if [[ ! -f "$target" ]]; then
          continue
        fi
        current_mtime="$(stat --format '%Y' "$target")"
        if [[ "$current_mtime" != "$last_mtime" ]]; then
          sync_target
          last_mtime="$current_mtime"
        fi
      done
    ) &
    watch_pid=$!
  fi
else
  dir_name="$(basename "$target")"

  sync_target() {
    local rel=""
    local dst=""

    find "$CONTENT_DIR" -mindepth 1 -delete
    find "$STATIC_DIR" -mindepth 1 -delete

    while IFS= read -r -d '' rel; do
      rel="${rel#./}"
      dst="$CONTENT_DIR/$rel"
      mkdir --parents "$(dirname "$dst")"
      strip_front_matter "$target/$rel" "$dst"
    done < <(list_markdown_files)
  }

  sync_target

  printf 'baseURL = "http://localhost:%d/"\ntitle = "%s"\ntheme = "gh-readme"\ndisableKinds = ["section", "taxonomy", "term", "RSS", "sitemap", "robotsTXT", "404"]\nenableEmoji = true\n\n[params]\n  dirMode = true\n\n[markup.goldmark.renderer]\n  unsafe = true\n\n[markup.goldmark.extensions]\n  strikethrough = true\n  linkify = true\n  taskList = true\n  footnote = true\n  typographer = true\n\n[markup.highlight]\n  noClasses = false\n\n[[module.mounts]]\n  source = "themes/gh-readme/assets"\n  target = "assets"\n\n[[module.mounts]]\n  source = "content"\n  target = "content"\n\n[[module.mounts]]\n  source = "static"\n  target = "static"\n' "$port" "$dir_name" > "$SITE_DIR/hugo.toml"

  if command -v inotifywait &>/dev/null; then
    (
      while read -r changed; do
        if [[ "$changed" == *.md || "$changed" == *.MD ]]; then
          sync_target
        fi
      done < <(
        inotifywait \
          --monitor \
          --recursive \
          --quiet \
          --event close_write,moved_to,create,delete \
          --format '%w%f' \
          "$target"
      )
    ) &
    watch_pid=$!
  else
    (
      last_state="$(
        list_markdown_files \
          | xargs --null stat --format '%Y %n' 2>/dev/null || true
      )"
      while true; do
        sleep 1
        current_state="$(
          list_markdown_files \
            | xargs --null stat --format '%Y %n' 2>/dev/null || true
        )"
        if [[ "$current_state" != "$last_state" ]]; then
          sync_target
          last_state="$current_state"
        fi
      done
    ) &
    watch_pid=$!
  fi
fi

hugo server \
  --source "$SITE_DIR" \
  --cacheDir "$HUGO_CACHE_DIR" \
  --port "$port" \
  --bind 127.0.0.1 \
  --disableFastRender \
  --renderToMemory \
  --noBuildLock &
hugo_pid=$!

for _ in $(seq 1 30); do
  ss -tln "sport = :$port" 2>/dev/null | grep -q "$port" && break
  sleep 0.1
done
if [[ "${GHRM_OPEN:-1}" != "0" ]] && command -v xdg-open &>/dev/null; then
  xdg-open "http://localhost:$port/" &>/dev/null &
fi

wait "$hugo_pid"
