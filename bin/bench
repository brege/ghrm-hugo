#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
GHRM_BIN="$SCRIPT_DIR/ghrm"
RUNS="${BENCH_RUNS:-3}"
WARMUPS="${BENCH_WARMUPS:-1}"
TIMEOUT_SECONDS="${BENCH_TIMEOUT_SECONDS:-30}"
OPEN_BROWSER="${BENCH_OPEN_BROWSER:-0}"
ENV_FILE="${BENCH_ENV_FILE:-$ROOT_DIR/.env}"

SITE_DIR="${BENCH_SITE_DIR:-}"
DEMO_DIR="${BENCH_DEMO_DIR:-}"
README_FILE="${BENCH_README_FILE:-}"

labels=()
ready_avgs=()
build_avgs=()

usage() {
  printf '%s\n' "usage: $(basename "$0") [--open-browser]"
  printf '%s\n' "loads benchmark targets from $ENV_FILE"
  printf '%s\n' "env overrides:"
  printf '%s\n' "  BENCH_ENV_FILE=$ENV_FILE"
  printf '%s\n' "  BENCH_RUNS=$RUNS"
  printf '%s\n' "  BENCH_WARMUPS=$WARMUPS"
  printf '%s\n' "  BENCH_TIMEOUT_SECONDS=$TIMEOUT_SECONDS"
  printf '%s\n' "  BENCH_OPEN_BROWSER=$OPEN_BROWSER"
  printf '%s\n' "  BENCH_SITE_DIR=$SITE_DIR"
  printf '%s\n' "  BENCH_DEMO_DIR=$DEMO_DIR"
  printf '%s\n' "  BENCH_README_FILE=$README_FILE"
}

load_env() {
  if [[ ! -f "$ENV_FILE" ]]; then
    printf '%s\n' "error: missing env file: $ENV_FILE" >&2
    printf '%s\n' "copy .env.example to .env and set benchmark paths" >&2
    exit 1
  fi

  set -a
  # shellcheck disable=SC1090
  . "$ENV_FILE"
  set +a

  SITE_DIR="${BENCH_SITE_DIR:-$SITE_DIR}"
  DEMO_DIR="${BENCH_DEMO_DIR:-$DEMO_DIR}"
  README_FILE="${BENCH_README_FILE:-$README_FILE}"
  RUNS="${BENCH_RUNS:-$RUNS}"
  WARMUPS="${BENCH_WARMUPS:-$WARMUPS}"
  TIMEOUT_SECONDS="${BENCH_TIMEOUT_SECONDS:-$TIMEOUT_SECONDS}"
  OPEN_BROWSER="${BENCH_OPEN_BROWSER:-$OPEN_BROWSER}"
}

now_ns() {
  date +%s%N
}

build_ms_from_log() {
  local log="$1"
  local line

  line="$(
    grep --extended-regexp --only-matching 'Built in [0-9]+ ms' "$log" \
      | tail --lines 1 || true
  )"

  if [[ -z "$line" ]]; then
    printf '%s\n' "0"
    return
  fi

  printf '%s\n' "${line#Built in }" | sed 's/ ms$//'
}

kill_server() {
  local pid="$1"

  if kill -0 "$pid" 2>/dev/null; then
    kill "$pid" 2>/dev/null || true
    wait "$pid" 2>/dev/null || true
  fi
}

start_hugo() {
  local dir="$1"
  local log="$2"

  (
    cd "$dir"
    if [[ "$OPEN_BROWSER" == "1" ]]; then
      exec hugo server --openBrowser >"$log" 2>&1
    fi

    exec hugo server >"$log" 2>&1
  ) &
  printf '%s\n' "$!"
}

start_ghrm() {
  local file="$1"
  local log="$2"

  if [[ "$OPEN_BROWSER" == "1" ]]; then
    "$GHRM_BIN" "$file" >"$log" 2>&1 &
    printf '%s\n' "$!"
    return
  fi

  GHRM_OPEN=0 "$GHRM_BIN" "$file" >"$log" 2>&1 &
  printf '%s\n' "$!"
}

measure_ready() {
  local kind="$1"
  local target="$2"
  local log="$3"
  local pid=""
  local start_ns
  local elapsed_ms
  local build_ms
  local timeout_at

  start_ns="$(now_ns)"
  timeout_at=$((SECONDS + TIMEOUT_SECONDS))

  if [[ "$kind" == "hugo" ]]; then
    pid="$(start_hugo "$target" "$log")"
  else
    pid="$(start_ghrm "$target" "$log")"
  fi

  while true; do
    if grep --quiet 'Web Server is available at' "$log"; then
      elapsed_ms="$((($(now_ns) - start_ns) / 1000000))"
      build_ms="$(build_ms_from_log "$log")"
      kill_server "$pid"
      printf '%s %s\n' "$elapsed_ms" "$build_ms"
      return
    fi

    if ! kill -0 "$pid" 2>/dev/null; then
      printf '%s\n' "error: benchmark target exited early: $target" >&2
      sed --quiet '1,220p' "$log" >&2 || true
      return 1
    fi

    if (( SECONDS >= timeout_at )); then
      kill_server "$pid"
      printf '%s\n' "error: timed out waiting for ready state: $target" >&2
      sed --quiet '1,220p' "$log" >&2 || true
      return 1
    fi

    sleep 0.02
  done
}

bench_case() {
  local label="$1"
  local kind="$2"
  local target="$3"
  local log
  local ready_ms
  local build_ms
  local sum_ready=0
  local sum_build=0
  local min_ready=0
  local max_ready=0

  printf '\n%s\n' "$label"
  printf '%s\n' "  target: $target"

  for run in $(seq 1 "$WARMUPS"); do
    log="$(mktemp /tmp/ghrm-bench-warmup-XXXXXX.log)"
    read -r ready_ms build_ms < <(measure_ready "$kind" "$target" "$log")
    printf '%s\n' "  warmup $run: ready=${ready_ms}ms build=${build_ms}ms"
  done

  for run in $(seq 1 "$RUNS"); do
    log="$(mktemp /tmp/ghrm-bench-run-XXXXXX.log)"
    read -r ready_ms build_ms < <(measure_ready "$kind" "$target" "$log")
    printf '%s\n' "  run $run: ready=${ready_ms}ms build=${build_ms}ms"

    sum_ready=$((sum_ready + ready_ms))
    sum_build=$((sum_build + build_ms))

    if (( min_ready == 0 || ready_ms < min_ready )); then
      min_ready="$ready_ms"
    fi

    if (( ready_ms > max_ready )); then
      max_ready="$ready_ms"
    fi
  done

  labels+=("$label")
  ready_avgs+=("$((sum_ready / RUNS))")
  build_avgs+=("$((sum_build / RUNS))")

  printf '%s\n' \
    "  avg ready=$((sum_ready / RUNS))ms min=${min_ready}ms max=${max_ready}ms avg build=$((sum_build / RUNS))ms"
}

print_summary() {
  local i

  printf '\n%s\n' "Summary"
  printf '%-18s %10s %10s\n' "case" "ready_avg" "build_avg"
  for i in "${!labels[@]}"; do
    printf '%-18s %10sms %10sms\n' \
      "${labels[$i]}" "${ready_avgs[$i]}" "${build_avgs[$i]}"
  done

  if (( ${#labels[@]} >= 3 )); then
    printf '\n%s\n' "Comparison"
    printf '%s\n' \
      "  ghrm minus site ready avg: $((ready_avgs[2] - ready_avgs[0]))ms"
    printf '%s\n' \
      "  ghrm minus demo ready avg: $((ready_avgs[2] - ready_avgs[1]))ms"
    printf '%s\n' \
      "  demo minus site ready avg: $((ready_avgs[1] - ready_avgs[0]))ms"
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help)
      usage
      exit 0
      ;;
    --open-browser)
      OPEN_BROWSER=1
      ;;
    *)
      printf '%s\n' "error: unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
  shift
done

load_env

if [[ -z "$SITE_DIR" ]]; then
  printf '%s\n' "error: BENCH_SITE_DIR is not set" >&2
  exit 1
fi

if [[ -z "$DEMO_DIR" ]]; then
  printf '%s\n' "error: BENCH_DEMO_DIR is not set" >&2
  exit 1
fi

if [[ -z "$README_FILE" ]]; then
  printf '%s\n' "error: BENCH_README_FILE is not set" >&2
  exit 1
fi

if [[ ! -d "$SITE_DIR" ]]; then
  printf '%s\n' "error: site dir not found: $SITE_DIR" >&2
  exit 1
fi

if [[ ! -d "$DEMO_DIR" ]]; then
  printf '%s\n' "error: demo dir not found: $DEMO_DIR" >&2
  exit 1
fi

if [[ ! -f "$README_FILE" ]]; then
  printf '%s\n' "error: readme file not found: $README_FILE" >&2
  exit 1
fi

if ! command -v hugo &>/dev/null; then
  printf '%s\n' "error: hugo not found in PATH" >&2
  exit 1
fi

bench_case "site" "hugo" "$SITE_DIR"
bench_case "theme-demo" "hugo" "$DEMO_DIR"
bench_case "ghrm-readme" "ghrm" "$README_FILE"
print_summary
